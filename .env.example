# SIEMGPT Enterprise Configuration
# Copy this to .env and fill in with your actual values

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
# SQLite (development)
# DATABASE_URL=sqlite:///./siemgpt.db

# PostgreSQL (production recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/siemgpt

# Elasticsearch Configuration
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_TIMEOUT=10
ELASTICSEARCH_RETRY=3

# SIEM Index Configuration
SIEM_INDEX_PATTERN=security-logs-*
SIEM_ALERTS_INDEX=alerts-*

# OpenAI Configuration (required for AI features)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Threat Intelligence APIs (optional)
ABUSEIPDB_API_KEY=your-api-key-here
VIRUSTOTAL_API_KEY=your-api-key-here

# Frontend Configuration
VITE_API_URL=/api/v1
VITE_WS_URL=ws://127.0.0.1:8000/api/v1/alerts/live
